# Copy this file to .env and fill in your values
# Never commit .env to version control

# Base URL of your order management platform
PLATFORM_BASE_URL=https://your-platform.example.com

# Directory to save debug screenshots (optional)
SCREENSHOT_DIR=/path/to/screenshots

# Platform credentials (used at runtime, not hardcoded)
PLATFORM_USERNAME=your@email.com
PLATFORM_PASSWORD=yourpassword
